// DomusGes — Prisma schema
// Salud: gestión de visitas domiciliarias para terapia ocupacional y afines.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Professional {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   // Fisioterapeuta | Terapeuta Ocupacional | Psicólogo/a Clínico/a | ...
  numColegiado String?
  phone        String?
  passwordHash String
  isActive     Boolean  @default(true)
  isAdmin      Boolean  @default(false)
  color        String   @default("#1a5c58")
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patients     Patient[]     @relation("PatientTherapists")
  visits       Visit[]
  assessments  Assessment[]
  appointments Appointment[]
  slotReservations SlotReservation[]
  auditLogs    AuditLog[]

  @@index([isActive])
}

model Patient {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  birthDate     DateTime
  specialty     String   // Fisioterapia | Psicología | T. Ocupacional
  status        String   @default("Activo") // Activo | En seguimiento | Alta | Pausado
  phone         String?
  address       String?
  diagnosis     String?
  objective     String?
  startDate     DateTime @default(now())
  referentName  String?
  referentPhone String?
  color         String   @default("#1a5c58")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  therapists    Professional[] @relation("PatientTherapists")
  visits        Visit[]
  assessments   Assessment[]
  appointments  Appointment[]
  occupationalProfile OccupationalProfile?

  @@index([status])
  @@index([specialty])
}

model Visit {
  id            String   @id @default(cuid())
  patientId     String
  therapistId   String
  date          DateTime
  durationMin   Int      @default(45)
  title         String?  // Optional so existing rows created before this field remain valid
  notes         String
  interventions String   @default("[]") // JSON-encoded string[]
  score         Int?     // 0-10 subjective progress
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist     Professional  @relation(fields: [therapistId], references: [id])

  @@index([patientId, date])
  @@index([therapistId, date])
}

model Assessment {
  id          String   @id @default(cuid())
  patientId   String
  therapistId String
  scale       String   // EVN | Barthel | Lawton-Brody | VAVDI | PHQ-9 | GAD-7
  score       String   // "5", "5/8", "12/27" — normalized later for charts
  itemScores  String?  // JSON-encoded Record<string, number> — only set for
                        // structured scales (Barthel, Lawton-Brody, VAVDI),
                        // where each key is an item id and value its score.
                        // Free-text scales (EVN, PHQ-9, GAD-7) leave this null.
  areaSummary String?  // JSON-encoded AreaSummaryData (see src/lib/scales.ts):
                        // strengths/areas-to-work-on grouped by clinical
                        // block, computed and stored at save time (Barthel/
                        // VAVDI only) — stored rather than recomputed on
                        // read, so a past assessment's conclusion doesn't
                        // silently change if the scoring rules evolve.
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist   Professional @relation(fields: [therapistId], references: [id])

  @@index([patientId, scale, date])
}

model Appointment {
  id          String   @id @default(cuid())
  patientId   String
  therapistId String
  start       DateTime
  durationMin Int      @default(45)
  type        String   // Sesión | Valoración | Seguimiento | Coordinación
  status      String   @default("programada") // programada | completada | cancelada | no_show
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist   Professional @relation(fields: [therapistId], references: [id])

  @@index([therapistId, start])
  @@index([patientId, start])
  @@index([start])
}

model SlotReservation {
  id          String   @id @default(cuid())
  therapistId String
  title       String
  start       DateTime
  durationMin Int      @default(45)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  therapist   Professional @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, start])
  @@index([start])
}

model AuditLog {
  id            String   @id @default(cuid())
  professionalId String?
  action        String   // patient.create | patient.view | visit.create | professional.update | ...
  entityType    String   // Patient | Visit | Professional | Assessment | Appointment
  entityId      String?
  metadata      String?  // JSON
  ipAddress     String?
  createdAt     DateTime @default(now())

  professional  Professional? @relation(fields: [professionalId], references: [id])

  @@index([action, createdAt])
  @@index([entityType, entityId])
}
model OccupationalProfile {
  id        String   @id @default(cuid())
  patientId String  @unique

  documentsAttached String?
  interventionReason String?
  referralResource String?

  drivingLicense String?
  currentlyDrives Boolean?
  drivingReason String?
  maritalStatus String?
  partnerInfo String?
  otherSocialInfo String?
  livingSituation String?

  familyComposition String? // JSON
  supportNetwork String? // JSON
  bestRelationship String?
  worstRelationship String?

  educationLevel String?
  otherEducation String?
  workHistory String? // JSON
  currentWorkSituation String?
  currentOccupation String?
  approximateIncome String?
  moneyManager String?
  incomeOrganization String?

  dailyRoutine String?
  selfCare String?
  domesticTasks String?
  responsibilities String?
  leisure String?
  physicalActivity String?
  socialParticipation String?

  leisureActivitiesCurrent String?
  leisureActivitiesPast String?
  sportsCurrent String?
  sportsPast String?
  trainingCurrent String?
  trainingPast String?

  desiredImprovements String?
  shortTermGoal1 String?
  shortTermGoal2 String?
  shortTermGoal3 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}
